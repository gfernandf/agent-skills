{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agent-skills://schemas/RuntimeEvent",
  "title": "RuntimeEvent",
  "description": "Lightweight execution event for tracing and inspection.",
  "type": "object",
  "required": [
    "type",
    "message",
    "timestamp"
  ],
  "properties": {
    "type": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "step_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "trace_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "data": {
      "type": "object"
    }
  }
}
