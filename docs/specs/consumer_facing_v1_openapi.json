{
  "openapi": "3.0.3",
  "info": {
    "title": "Agent Skills Consumer-Facing API",
    "version": "1.0.0",
    "description": "Protocol-neutral customer-facing API over the runtime engine."
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8080"
    }
  ],
  "paths": {
    "/v1/health": {
      "get": {
        "operationId": "health",
        "responses": {
          "200": {
            "description": "Health response"
          }
        }
      }
    },
    "/v1/skills/{skill_id}/describe": {
      "get": {
        "operationId": "describeSkill",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "name": "skill_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Skill description"
          },
          "401": {
            "description": "Missing API key"
          },
          "403": {
            "description": "Invalid API key"
          },
          "429": {
            "description": "Rate limited"
          },
          "404": {
            "description": "Skill not found"
          }
        }
      }
    },
    "/v1/skills/{skill_id}/execute": {
      "post": {
        "operationId": "executeSkill",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "name": "skill_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-trace-id",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "inputs": {
                    "type": "object"
                  },
                  "trace_id": {
                    "type": "string"
                  },
                  "include_trace": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Skill execution result"
          },
          "401": {
            "description": "Missing API key"
          },
          "403": {
            "description": "Invalid API key"
          },
          "429": {
            "description": "Rate limited"
          },
          "400": {
            "description": "Invalid request"
          },
          "404": {
            "description": "Skill not found"
          },
          "500": {
            "description": "Runtime error"
          }
        }
      }
    },
    "/v1/skills/list": {
      "get": {
        "operationId": "listSkills",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "name": "domain",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "role",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "invocation",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Skill list"
          },
          "401": {
            "description": "Missing API key"
          },
          "403": {
            "description": "Invalid API key"
          },
          "429": {
            "description": "Rate limited"
          }
        }
      }
    },
    "/v1/skills/diagnostics": {
      "get": {
        "operationId": "gatewayDiagnostics",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Gateway diagnostics with cache metrics"
          },
          "401": {
            "description": "Missing API key"
          },
          "403": {
            "description": "Invalid API key"
          },
          "429": {
            "description": "Rate limited"
          }
        }
      }
    },
    "/v1/skills/discover": {
      "post": {
        "operationId": "discoverSkills",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "intent"
                ],
                "properties": {
                  "intent": {
                    "type": "string"
                  },
                  "domain": {
                    "type": "string"
                  },
                  "role": {
                    "type": "string"
                  },
                  "limit": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Ranked discovery results"
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Missing API key"
          },
          "403": {
            "description": "Invalid API key"
          },
          "429": {
            "description": "Rate limited"
          }
        }
      }
    },
    "/v1/skills/{skill_id}/attach": {
      "post": {
        "operationId": "attachSkill",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "name": "skill_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-trace-id",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "target_type",
                  "target_ref"
                ],
                "properties": {
                  "target_type": {
                    "type": "string"
                  },
                  "target_ref": {
                    "type": "string"
                  },
                  "inputs": {
                    "type": "object"
                  },
                  "trace_id": {
                    "type": "string"
                  },
                  "include_trace": {
                    "type": "boolean"
                  },
                  "required_conformance_profile": {
                    "type": "string"
                  },
                  "audit_mode": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Attach execution result"
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Missing API key"
          },
          "403": {
            "description": "Invalid API key"
          },
          "404": {
            "description": "Skill not found"
          },
          "429": {
            "description": "Rate limited"
          },
          "500": {
            "description": "Runtime error"
          }
        }
      }
    },
    "/v1/capabilities/{capability_id}/execute": {
      "post": {
        "operationId": "executeCapability",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "name": "capability_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-trace-id",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "inputs": {
                    "type": "object"
                  },
                  "trace_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Capability execution result"
          },
          "401": {
            "description": "Missing API key"
          },
          "403": {
            "description": "Invalid API key"
          },
          "429": {
            "description": "Rate limited"
          },
          "404": {
            "description": "Capability not found"
          },
          "500": {
            "description": "Runtime error"
          }
        }
      }
    },
    "/v1/capabilities/{capability_id}/explain": {
      "post": {
        "operationId": "explainCapabilityResolution",
        "summary": "Explain binding resolution chain for a capability.",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "name": "capability_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "required_conformance_profile": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Resolution plan with fallback chain"
          },
          "401": {
            "description": "Missing API key"
          },
          "403": {
            "description": "Invalid API key"
          },
          "404": {
            "description": "Capability not found"
          },
          "429": {
            "description": "Rate limited"
          },
          "500": {
            "description": "Runtime error"
          }
        }
      }
    },
    "/v1/skills/governance": {
      "get": {
        "operationId": "listSkillGovernance",
        "summary": "List skill governance catalog entries filtered by lifecycle state.",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "name": "min_state",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "draft",
                "validated",
                "lab-verified",
                "trusted",
                "recommended"
              ]
            },
            "description": "Minimum lifecycle state filter."
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20
            },
            "description": "Maximum entries to return."
          }
        ],
        "responses": {
          "200": {
            "description": "Governance catalog entries"
          },
          "401": {
            "description": "Missing API key"
          },
          "403": {
            "description": "Invalid API key"
          },
          "429": {
            "description": "Rate limited"
          }
        }
      }
    },
    "/v1/skills/{skill_id}/execute/stream": {
      "post": {
        "operationId": "executeSkillStream",
        "summary": "Execute a skill with Server-Sent Events streaming.",
        "description": "Returns an SSE stream with step_start, step_completed, and done events.",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "name": "skill_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExecuteRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SSE event stream",
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string",
                  "description": "Server-Sent Events stream. Each event has fields: event (type), data (JSON)."
                }
              }
            }
          },
          "401": {
            "description": "Missing API key"
          },
          "403": {
            "description": "Invalid API key"
          },
          "404": {
            "description": "Skill not found"
          },
          "429": {
            "description": "Rate limited"
          }
        }
      }
    },
    "/v1/skills/{skill_id}/execute/async": {
      "post": {
        "operationId": "executeSkillAsync",
        "summary": "Launch asynchronous skill execution.",
        "description": "Returns immediately with a run_id. Poll GET /v1/runs/{run_id} for status.",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "name": "skill_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExecuteRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Accepted — execution launched",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AsyncRunCreated"
                }
              }
            }
          },
          "401": {
            "description": "Missing API key"
          },
          "403": {
            "description": "Invalid API key"
          },
          "404": {
            "description": "Skill not found"
          },
          "429": {
            "description": "Rate limited"
          }
        }
      }
    },
    "/v1/runs/{run_id}": {
      "get": {
        "operationId": "getRun",
        "summary": "Get the status of an asynchronous run.",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "name": "run_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Run details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RunStatus"
                }
              }
            }
          },
          "401": {
            "description": "Missing API key"
          },
          "404": {
            "description": "Run not found"
          },
          "429": {
            "description": "Rate limited"
          }
        }
      }
    },
    "/v1/runs": {
      "get": {
        "operationId": "listRuns",
        "summary": "List all tracked asynchronous runs.",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Array of run summaries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "runs": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/RunStatus"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Missing API key"
          },
          "429": {
            "description": "Rate limited"
          }
        }
      }
    },
    "/v1/webhooks": {
      "get": {
        "operationId": "listWebhooks",
        "summary": "List webhook subscriptions",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "List of subscriptions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "subscriptions": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/WebhookSubscription"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Missing API key"
          },
          "403": {
            "description": "Invalid API key"
          }
        }
      },
      "post": {
        "operationId": "createWebhook",
        "summary": "Subscribe to webhook events",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WebhookCreateRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Subscription created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WebhookSubscription"
                }
              }
            }
          },
          "400": {
            "description": "Validation error"
          },
          "401": {
            "description": "Missing API key"
          }
        }
      }
    },
    "/v1/webhooks/{webhook_id}": {
      "delete": {
        "operationId": "deleteWebhook",
        "summary": "Unsubscribe a webhook",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "name": "webhook_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "deleted": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Not found"
          },
          "401": {
            "description": "Missing API key"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      }
    },
    "schemas": {
      "ExecuteRequest": {
        "type": "object",
        "properties": {
          "inputs": {
            "type": "object",
            "description": "Skill input parameters"
          },
          "options": {
            "type": "object",
            "properties": {
              "fail_fast": {
                "type": "boolean",
                "default": true
              },
              "max_workers": {
                "type": "integer"
              },
              "audit_mode": {
                "type": "string",
                "enum": [
                  "off",
                  "standard",
                  "full"
                ]
              }
            }
          },
          "trace_id": {
            "type": "string",
            "description": "Optional correlation ID"
          }
        },
        "required": [
          "inputs"
        ]
      },
      "AsyncRunCreated": {
        "type": "object",
        "properties": {
          "run_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending"
            ]
          }
        },
        "required": [
          "run_id",
          "status"
        ]
      },
      "RunStatus": {
        "type": "object",
        "properties": {
          "run_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "running",
              "completed",
              "failed"
            ]
          },
          "skill_id": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "finished_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "result": {
            "type": "object",
            "nullable": true
          },
          "error": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "run_id",
          "status"
        ]
      },
      "WebhookCreateRequest": {
        "type": "object",
        "required": [
          "url",
          "events"
        ],
        "properties": {
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Endpoint URL to receive POST deliveries"
          },
          "events": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Event types: skill.started, skill.completed, skill.failed, run.completed, run.failed, or * for all"
          },
          "secret": {
            "type": "string",
            "description": "Shared secret for HMAC-SHA256 signature verification"
          }
        }
      },
      "WebhookSubscription": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "events": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "active": {
            "type": "boolean"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "description": "Canonical error response (see docs/ERROR_TAXONOMY.md).",
        "required": ["error"],
        "properties": {
          "error": {
            "type": "object",
            "required": ["code", "message", "type", "status"],
            "properties": {
              "code": {
                "type": "string",
                "description": "Stable machine-readable error code.",
                "enum": [
                  "capability_not_found",
                  "invalid_request",
                  "validation_error",
                  "binding_not_found",
                  "binding_execution_error",
                  "step_execution_error",
                  "step_timeout",
                  "wiring_error",
                  "dag_cycle",
                  "depth_limit",
                  "conformance_error",
                  "safety_blocked",
                  "auth_required",
                  "permission_denied",
                  "rate_limited",
                  "internal_error"
                ]
              },
              "message": {
                "type": "string",
                "description": "Human-readable error description."
              },
              "type": {
                "type": "string",
                "description": "Exception class name."
              },
              "status": {
                "type": "integer",
                "description": "HTTP status code."
              }
            }
          },
          "trace_id": {
            "type": "string",
            "nullable": true
          }
        }
      }
    }
  }
}
