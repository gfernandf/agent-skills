{
  "openapi": "3.0.3",
  "info": {
    "title": "Agent Skills Consumer-Facing API",
    "version": "1.0.0",
    "description": "Protocol-neutral customer-facing API over the runtime engine."
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8080"
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      }
    }
  },
  "paths": {
    "/v1/health": {
      "get": {
        "operationId": "health",
        "responses": {
          "200": {
            "description": "Health response"
          }
        }
      }
    },
    "/v1/skills/{skill_id}/describe": {
      "get": {
        "operationId": "describeSkill",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "name": "skill_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Skill description"
          },
          "401": {
            "description": "Missing API key"
          },
          "403": {
            "description": "Invalid API key"
          },
          "429": {
            "description": "Rate limited"
          },
          "404": {
            "description": "Skill not found"
          }
        }
      }
    },
    "/v1/skills/{skill_id}/execute": {
      "post": {
        "operationId": "executeSkill",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "name": "skill_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-trace-id",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "inputs": {
                    "type": "object"
                  },
                  "trace_id": {
                    "type": "string"
                  },
                  "include_trace": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Skill execution result"
          },
          "401": {
            "description": "Missing API key"
          },
          "403": {
            "description": "Invalid API key"
          },
          "429": {
            "description": "Rate limited"
          },
          "400": {
            "description": "Invalid request"
          },
          "404": {
            "description": "Skill not found"
          },
          "500": {
            "description": "Runtime error"
          }
        }
      }
    },
    "/v1/capabilities/{capability_id}/execute": {
      "post": {
        "operationId": "executeCapability",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "name": "capability_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-trace-id",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "inputs": {
                    "type": "object"
                  },
                  "trace_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Capability execution result"
          },
          "401": {
            "description": "Missing API key"
          },
          "403": {
            "description": "Invalid API key"
          },
          "429": {
            "description": "Rate limited"
          },
          "404": {
            "description": "Capability not found"
          },
          "500": {
            "description": "Runtime error"
          }
        }
      }
    }
  }
}
