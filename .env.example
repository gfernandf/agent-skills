# ── Environment variables for Agent Skills Runtime ──
# Copy this file to .env and fill in the values you need.
# The runtime reads these from the process environment (not from this file directly).

# ── LLM Provider (required for OpenAI-backed capabilities) ──
OPENAI_API_KEY=

# ── Filesystem sandbox (optional) ──
# Root directory for fs.file.read capability. Defaults to working directory.
# AGENT_SKILLS_FS_ROOT=

# ── Debug logging (optional) ──
# Set to any value to enable verbose debug logs in artifacts/openai_debug.log.
# AGENT_SKILLS_DEBUG=1

# ── Audit layer (optional) ──
# Default audit mode: off | standard | full. Defaults to standard.
# AGENT_SKILLS_AUDIT_DEFAULT_MODE=standard

# ── HTTP server (optional, for customer-facing API) ──
# AGENT_SKILLS_API_KEY=your-server-api-key
# AGENT_SKILLS_HOST=127.0.0.1
# AGENT_SKILLS_PORT=8080
